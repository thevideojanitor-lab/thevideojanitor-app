# ── Supabase ─────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# ── Stripe (client-side) ─────────────────────────────────────
# Get from: https://dashboard.stripe.com/test/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ── Edge Function secrets (set via: npx supabase secrets set --env-file .env) ──
# These are NOT prefixed with VITE_ — server-only, never exposed to the browser

# Stripe secret + webhook signing secret
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Stripe Price IDs — create products in https://dashboard.stripe.com/test/products
STRIPE_PRICE_QS_MONTHLY=price_xxx
STRIPE_PRICE_QS_ANNUAL=price_xxx
STRIPE_PRICE_DC_MONTHLY=price_xxx
STRIPE_PRICE_DC_ANNUAL=price_xxx
STRIPE_PRICE_FS_MONTHLY=price_xxx
STRIPE_PRICE_FS_ANNUAL=price_xxx

# Stripe Credit Pack Price IDs (one-time payments)
STRIPE_PRICE_CREDITS_SMALL=price_xxx
STRIPE_PRICE_CREDITS_MEDIUM=price_xxx
STRIPE_PRICE_CREDITS_LARGE=price_xxx

# Razorpay — https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
